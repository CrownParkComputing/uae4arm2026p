<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FF222222">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- About Section -->
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:adjustViewBounds="true"
            android:scaleType="centerInside"
            android:src="@drawable/featured_default" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/app_name"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtAboutVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text=""
            android:textColor="#AAAAAA"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/txtAboutBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Based on UAE4ARM and Amiberry.\nPorted to Android 2024-2026.\n\nFor documentation and support, visit the project GitHub."
            android:textColor="#CCCCCC"
            android:textSize="12sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="#444444" />

        <!-- Help Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Setup Help"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Kickstart ROMs"
            android:textColor="#AAAAAA"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="To run Amiga models correctly, you need Kickstart ROM files.\n\n1. Place your .rom files in a folder on your device.\n2. Use the 'Paths' button to select your config/ROMs parent folder.\n3. Use 'Kickstart Map' to manually assign ROMs if they are not detected."
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:paddingBottom="24dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Paths"
            android:textColor="#AAAAAA"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="On newer Android versions, you must grant access to folders using the System File Picker (SAF).\n\n- Click 'Paths'.\n- Click 'Select Parent Folder'.\n- Choose a folder where you store Configs, ROMs, and Disks.\n\nThis ensures the emulator can save configurations and read your files."
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:paddingBottom="24dp" />

        <Button
            android:id="@+id/btnRerunWalkthrough"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Rerun Setup Walkthrough"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnClose"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Close" />

    </LinearLayout>
</ScrollView>
