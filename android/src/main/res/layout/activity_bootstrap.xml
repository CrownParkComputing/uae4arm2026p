<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/bootstrapScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/bootstrapRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="4dp">

            <TextView
                android:id="@+id/txtTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quickstart"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingBottom="0dp"
                android:visibility="gone" />

            <!-- Start / Restart / Cold Reset row (moved above media section to free strip space) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="end|center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <Button
                    android:id="@+id/btnStartPanel"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    style="@style/IconChipSmall"
                    android:textSize="11sp"
                    android:background="@android:color/transparent"
                    android:drawableTop="@drawable/ic_play_white"
                    android:drawablePadding="2dp"
                    android:textColor="@android:color/white"
                    android:text="PLAY" />

                <Button
                    android:id="@+id/btnAgsPanel"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="10dp"
                    style="@style/IconChipSmall"
                    android:textSize="11sp"
                    android:background="@android:color/transparent"
                    android:drawablePadding="2dp"
                    android:textColor="@android:color/white"
                    android:text="AGS" />

                <Button
                    android:id="@+id/btnRestart"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="10dp"
                    style="@style/IconChipSmall"
                    android:textSize="11sp"
                    android:background="@android:color/transparent"
                    android:drawableTop="@drawable/ic_restart_white"
                    android:drawablePadding="2dp"
                    android:textColor="@android:color/white"
                    android:text="RESTART" />

                <Button
                    android:id="@+id/btnColdReset"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="2dp"
                    style="@style/IconChipSmall"
                    android:textSize="11sp"
                    android:background="@android:color/transparent"
                    android:drawableTop="@drawable/ic_close_white"
                    android:drawablePadding="2dp"
                    android:textColor="@android:color/white"
                    android:text="EXIT" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/sectionMedia"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="0dp"
                android:background="@drawable/bg_section_media"
                android:orientation="vertical"
                android:padding="2dp">

                <!-- Model + Config selectors (hidden, kept for Java compat) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Model"
                            android:textSize="9sp"
                            android:textColor="?android:attr/textColorSecondary" />

                        <Spinner
                            android:id="@+id/spinnerQsModelLegacy"
                            android:layout_width="match_parent"
                            android:layout_height="32dp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1.3"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Config"
                            android:textSize="9sp"
                            android:textColor="?android:attr/textColorSecondary" />

                        <Spinner
                            android:id="@+id/spinnerQsConfig"
                            android:layout_width="match_parent"
                            android:layout_height="32dp" />

                        <TextView
                            android:id="@+id/txtQsConfigFull"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:textSize="9sp"
                            android:textColor="?android:attr/textColorSecondary"
                            android:text="" />

                    </LinearLayout>
                </LinearLayout>

                <!-- Kickstart status row with KS button on the left -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageButton
                        android:id="@+id/iconBtnKick"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        style="@style/IconChipSmall"
                        android:padding="2dp"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/featured_kickstart_check"
                        android:scaleType="fitCenter"
                        android:contentDescription="Kickstart" />

                    <TextView
                        android:id="@+id/txtKickStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="Kickstart: (not selected)"
                        android:textSize="11sp"
                        android:singleLine="false"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:visibility="visible" />

                    <ImageButton
                        android:id="@+id/btnConfigsTop"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="6dp"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Configs"
                        android:padding="8dp"
                        android:src="@android:drawable/ic_menu_manage" />

                </LinearLayout>

                <!-- Hidden quick-access buttons (kept for Java compat) -->
                <LinearLayout
                    android:id="@+id/layoutModelQuickRow1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:visibility="visible">
                    <Button android:id="@+id/btnModelChipset" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Chipset" android:textSize="12sp" />
                    <Button android:id="@+id/btnModelRam" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:layout_weight="1" android:text="RAM" android:textSize="12sp" />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/layoutModelQuickRow2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:visibility="visible">
                    <Button android:id="@+id/btnModelInput" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Input" android:textSize="12sp" />
                    <Button android:id="@+id/btnKickMap" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:layout_weight="1" android:text="Kickstart" android:textSize="12sp" />
                </LinearLayout>



                <!-- MODEL ROW: model selector + easy setup left, Amiga graphic right -->
                <LinearLayout
                    android:id="@+id/modelRow"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="0dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Model selector + easy setup (compact) -->
                    <ScrollView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:scrollbars="vertical"
                        android:fadingEdge="vertical">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Model"
                                android:textSize="10sp"
                                android:textStyle="bold" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <Spinner
                                    android:id="@+id/spinnerQsModel"
                                    android:layout_width="0dp"
                                    android:layout_height="40dp"
                                    android:layout_weight="1"
                                    android:layout_marginEnd="2dp"
                                    android:background="#111111" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="6dp"
                                    android:orientation="horizontal"
                                    android:gravity="end|center_vertical">

                                    <CheckBox
                                        android:id="@+id/chkEasyJit"
                                        android:layout_width="wrap_content"
                                        android:layout_height="32dp"
                                        android:minHeight="0dp"
                                        android:padding="0dp"
                                        android:text="JIT"
                                        android:textSize="9sp" />

                                    <CheckBox
                                        android:id="@+id/chkEasyRtg"
                                        android:layout_width="wrap_content"
                                        android:layout_height="32dp"
                                        android:layout_marginStart="10dp"
                                        android:minHeight="0dp"
                                        android:padding="0dp"
                                        android:text="RTG"
                                        android:textSize="9sp" />
                                </LinearLayout>
                            </LinearLayout>

                            <LinearLayout
                                android:id="@+id/layoutQuickEasySetup"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:orientation="vertical"
                                android:padding="2dp"
                                android:background="@drawable/bg_section_model"
                                android:visibility="visible">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="1dp"
                                    android:orientation="horizontal">

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:layout_marginEnd="2dp">

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:text="Chip"
                                            android:textSize="9sp" />

                                        <LinearLayout
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:orientation="horizontal">

                                            <Spinner
                                                android:id="@+id/spinnerEasyChip"
                                                android:layout_width="0dp"
                                                android:layout_height="40dp"
                                                android:layout_weight="1"
                                                android:layout_marginEnd="1dp"
                                                android:background="#111111" />

                                            <Space
                                                android:layout_width="0dp"
                                                android:layout_height="1dp"
                                                android:layout_weight="1" />
                                        </LinearLayout>
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:layout_marginStart="2dp"
                                        android:layout_marginEnd="2dp">

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:text="Fast"
                                            android:textSize="9sp" />

                                        <LinearLayout
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:orientation="horizontal">

                                            <Spinner
                                                android:id="@+id/spinnerEasyFast"
                                                android:layout_width="0dp"
                                                android:layout_height="40dp"
                                                android:layout_weight="1"
                                                android:layout_marginEnd="1dp"
                                                android:background="#111111" />

                                            <Space
                                                android:layout_width="0dp"
                                                android:layout_height="1dp"
                                                android:layout_weight="1" />
                                        </LinearLayout>
                                    </LinearLayout>

                                    <LinearLayout
                                        android:id="@+id/layoutEasyZ3"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:orientation="vertical"
                                        android:layout_marginStart="2dp"
                                        android:visibility="gone">

                                        <TextView
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:text="Z3"
                                            android:textSize="9sp" />

                                        <LinearLayout
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:orientation="horizontal">

                                            <Spinner
                                                android:id="@+id/spinnerEasyZ3"
                                                android:layout_width="0dp"
                                                android:layout_height="40dp"
                                                android:layout_weight="1"
                                                android:layout_marginEnd="1dp"
                                                android:background="#111111" />

                                            <Space
                                                android:layout_width="0dp"
                                                android:layout_height="1dp"
                                                android:layout_weight="1" />
                                        </LinearLayout>
                                    </LinearLayout>
                                </LinearLayout>
                            </LinearLayout>
                        </LinearLayout>
                    </ScrollView>

                    <!-- Media actions (vertical, left of Amiga graphic) -->
                    <LinearLayout
                        android:id="@+id/mediaActionsColumn"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                    </LinearLayout>

                    <!-- Amiga model image (long-press = config) -->
                    <ImageView
                        android:id="@+id/imgAmigaModel"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.5"
                        android:scaleType="fitCenter"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?android:attr/selectableItemBackground"
                        android:contentDescription="Amiga model"
                        android:src="@drawable/featured_a500" />

                </LinearLayout>

                <TextView
                    android:id="@+id/txtInsertedMediaSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Inserted: (none)"
                    android:textSize="9sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:singleLine="true"
                    android:ellipsize="end" />

                <!-- DF0 status (clickable: tap to insert floppy) -->
                <TextView
                    android:id="@+id/txtDf0Status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground"
                    android:text="DF0: (empty &#8212; tap to insert)"
                    android:textSize="10sp"
                    android:visibility="gone" />

                <!-- DRIVES STRIP: individual icons for each active drive -->
                <HorizontalScrollView
                    android:id="@+id/drivesStrip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:scrollbars="none"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/drivesStripContent"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical" />

                </HorizontalScrollView>

                <!-- Ext ROM (CD32 only, shown at bottom of media section) -->
                <LinearLayout
                    android:id="@+id/extRomSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_section_kickstart"
                    android:orientation="vertical"
                    android:padding="6dp"
                    android:visibility="gone">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingBottom="4dp" android:text="CD32 Extended ROM" android:textStyle="bold" android:textSize="12sp" />
                    <TextView android:id="@+id/txtExtStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Ext ROM: (not selected)" android:textSize="12sp" />
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/quickstartReturnBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_section_model"
                android:padding="2dp"
                android:visibility="visible">

                <Button
                    android:id="@+id/btnResumeToEmu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="#2E7D32"
                    android:textColor="#FFFFFF"
                    style="@style/QuickButtonPrimary"
                    android:text="Resume" />

                <Button
                    android:id="@+id/btnRestartEmu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="#2E7D32"
                    android:textColor="#FFFFFF"
                    style="@style/QuickButtonPrimary"
                    android:text="Restart" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnCdCorner"
        android:layout_width="wrap_content"
        android:layout_height="96dp"
        style="@style/IconChipSmall"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="8dp"
        android:background="@android:color/transparent"
        android:text="💿 Load CD"
        android:textColor="@android:color/white"
        android:textSize="30sp"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/splashImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/splash_screen"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:background="#000000" />
</FrameLayout>
