<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/bootstrapScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/bootstrapRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="4dp">

            <TextView
                android:id="@+id/txtTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quickstart"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingBottom="0dp"
                android:visibility="gone" />

            <!-- Start / Restart / Cold Reset row (moved above media section to free strip space) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="end|center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <Button
                    android:id="@+id/btnStartPanel"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    style="@style/IconChipSmall"
                    android:textSize="11sp"
                    android:background="@android:color/transparent"
                    android:drawableTop="@drawable/ic_play_white"
                    android:drawablePadding="2dp"
                    android:textColor="@android:color/white"
                    android:text="PLAY" />

                <Button
                    android:id="@+id/btnAgsPanel"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="10dp"
                    style="@style/IconChipSmall"
                    android:textSize="11sp"
                    android:background="@android:color/transparent"
                    android:drawablePadding="2dp"
                    android:textColor="@android:color/white"
                    android:text="AGS" />

                <Button
                    android:id="@+id/btnRestart"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="10dp"
                    style="@style/IconChipSmall"
                    android:textSize="11sp"
                    android:background="@android:color/transparent"
                    android:drawableTop="@drawable/ic_restart_white"
                    android:drawablePadding="2dp"
                    android:textColor="@android:color/white"
                    android:text="RESTART" />

                <Button
                    android:id="@+id/btnColdReset"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="2dp"
                    style="@style/IconChipSmall"
                    android:textSize="11sp"
                    android:background="@android:color/transparent"
                    android:drawableTop="@drawable/ic_close_white"
                    android:drawablePadding="2dp"
                    android:textColor="@android:color/white"
                    android:text="EXIT" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/sectionMedia"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="0dp"
                android:background="@drawable/bg_section_media"
                android:orientation="vertical"
                android:padding="2dp">

                <!-- Model + Config selectors (hidden, kept for Java compat) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Model"
                            android:textSize="9sp"
                            android:textColor="?android:attr/textColorSecondary" />

                        <Spinner
                            android:id="@+id/spinnerQsModelLegacy"
                            android:layout_width="match_parent"
                            android:layout_height="32dp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1.3"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Config"
                            android:textSize="9sp"
                            android:textColor="?android:attr/textColorSecondary" />

                        <Spinner
                            android:id="@+id/spinnerQsConfig"
                            android:layout_width="match_parent"
                            android:layout_height="32dp" />

                        <TextView
                            android:id="@+id/txtQsConfigFull"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:textSize="9sp"
                            android:textColor="?android:attr/textColorSecondary"
                            android:text="" />

                    </LinearLayout>
                </LinearLayout>

                <!-- Kickstart status row with KS button on the left -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageButton
                        android:id="@+id/iconBtnKick"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        style="@style/IconChipSmall"
                        android:padding="2dp"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/featured_kickstart_check"
                        android:scaleType="fitCenter"
                        android:contentDescription="Kickstart" />

                    <TextView
                        android:id="@+id/txtKickStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:text="Kickstart: (not selected)"
                        android:textSize="11sp"
                        android:singleLine="false"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:visibility="visible" />

                    <Button
                        android:id="@+id/btnConfigsTop"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginStart="6dp"
                        android:background="?android:attr/selectableItemBackground"
                        android:text="Configs"
                        android:textSize="11sp"
                        android:textColor="@android:color/white"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp" />

                </LinearLayout>

                <!-- Hidden quick-access buttons (kept for Java compat) -->
                <LinearLayout
                    android:id="@+id/layoutModelQuickRow1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal"
                    android:visibility="visible">
                    <Button android:id="@+id/btnModelChipset" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Chipset" android:textSize="12sp" />
                    <Button android:id="@+id/btnModelRam" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:layout_weight="1" android:text="RAM" android:textSize="12sp" />
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/layoutModelQuickRow2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    android:visibility="visible">
                    <Button android:id="@+id/btnModelInput" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Input" android:textSize="12sp" />
                    <Button android:id="@+id/btnKickMap" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:layout_weight="1" android:text="Kickstart" android:textSize="12sp" />
                </LinearLayout>



                <!-- MODEL ROW: model selector + easy setup left, Amiga graphic right -->
                <LinearLayout
                    android:id="@+id/modelRow"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="0dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Model selector + easy setup (compact) -->
                    <ScrollView
                        android:id="@+id/modelLeftColumn"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:scrollbars="vertical"
                        android:fadingEdge="vertical">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <!-- Hidden model spinner (kept for Java compat) -->
                            <Spinner
                                android:id="@+id/spinnerQsModel"
                                android:layout_width="0dp"
                                android:layout_height="0dp"
                                android:visibility="gone" />

                            <!-- Memory row: Chip + Fast + Z3 (Z3 shown when RTG checked) -->
                            <LinearLayout
                                android:id="@+id/layoutQuickEasySetup"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:orientation="horizontal"
                                android:padding="4dp"
                                android:background="@drawable/bg_section_model"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Chip"
                                    android:textSize="9sp"
                                    android:layout_marginEnd="4dp" />

                                <Spinner
                                    android:id="@+id/spinnerEasyChip"
                                    android:layout_width="0dp"
                                    android:layout_height="32dp"
                                    android:layout_weight="1"
                                    android:layout_marginEnd="8dp"
                                    android:background="#111111" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Fast"
                                    android:textSize="9sp"
                                    android:layout_marginEnd="4dp" />

                                <Spinner
                                    android:id="@+id/spinnerEasyFast"
                                    android:layout_width="0dp"
                                    android:layout_height="32dp"
                                    android:layout_weight="1"
                                    android:background="#111111" />

                                <!-- Z3 (shown only when RTG checked) -->
                                <LinearLayout
                                    android:id="@+id/layoutEasyZ3"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginStart="8dp"
                                    android:visibility="gone">

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Z3"
                                        android:textSize="9sp"
                                        android:layout_marginEnd="4dp" />

                                    <Spinner
                                        android:id="@+id/spinnerEasyZ3"
                                        android:layout_width="80dp"
                                        android:layout_height="32dp"
                                        android:background="#111111" />
                                </LinearLayout>

                            </LinearLayout>

                            <!-- Options row: JIT + RTG (moved here from above image) -->
                            <LinearLayout
                                android:id="@+id/layoutEasyOptionsRow"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:paddingStart="4dp"
                                android:paddingEnd="4dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp"
                                android:gravity="start|center_vertical">

                                <CheckBox
                                    android:id="@+id/chkEasyJit"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginEnd="12dp"
                                    android:text="JIT"
                                    android:textSize="10sp" />

                                <CheckBox
                                    android:id="@+id/chkEasyRtg"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="RTG"
                                    android:textSize="10sp" />

                            </LinearLayout>

                            <!-- Game cover art (shown when DF0 has a game) -->
                            <ImageView
                                android:id="@+id/imgGameCover"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:maxHeight="120dp"
                                android:scaleType="fitCenter"
                                android:adjustViewBounds="true"
                                android:contentDescription="Game cover"
                                android:visibility="gone" />

                        </LinearLayout>
                    </ScrollView>

                    <!-- Media actions (vertical, left of Amiga graphic) -->
                    <LinearLayout
                        android:id="@+id/mediaActionsColumn"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                    </LinearLayout>

                    <!-- Amiga model image: swipe left/right to change model -->
                    <FrameLayout
                        android:id="@+id/modelImageContainer"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.5"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:id="@+id/imgAmigaModel"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:clickable="true"
                            android:focusable="true"
                            android:contentDescription="Amiga model"
                            android:src="@drawable/featured_a500" />

                        <!-- Left arrow hint -->
                        <TextView
                            android:id="@+id/arrowLeft"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="start|center_vertical"
                            android:text="◀"
                            android:textSize="18sp"
                            android:textColor="#80FFFFFF"
                            android:paddingStart="2dp"
                            android:paddingEnd="2dp" />

                        <!-- Right arrow hint -->
                        <TextView
                            android:id="@+id/arrowRight"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="end|center_vertical"
                            android:text="▶"
                            android:textSize="18sp"
                            android:textColor="#80FFFFFF"
                            android:paddingStart="2dp"
                            android:paddingEnd="2dp" />

                        <!-- Model name overlay -->
                        <TextView
                            android:id="@+id/txtModelName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="bottom|center_horizontal"
                            android:text="Amiga 500"
                            android:textSize="11sp"
                            android:textColor="#CCFFFFFF"
                            android:background="#80000000"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp" />

                    </FrameLayout>

                </LinearLayout>

                <!-- DF0 status (hidden) -->
                <TextView
                    android:id="@+id/txtDf0Status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="0dp"
                    android:paddingBottom="0dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?android:attr/selectableItemBackground"
                    android:text="DF0: (empty &#8212; tap to insert)"
                    android:textSize="10sp"
                    android:visibility="gone" />

                <!-- DRIVES STRIP: two horizontally-scrollable rows (DF row + DH row) -->
                <LinearLayout
                    android:id="@+id/drivesStrip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:id="@+id/drivesStripContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>

                <!-- CD Panel: shown for CD32/CDTV instead of drives strip -->
                <LinearLayout
                    android:id="@+id/cdPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/txtCdDiscStatus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No disc loaded"
                        android:textSize="11sp"
                        android:textColor="#AAFFFFFF"
                        android:gravity="center"
                        android:ellipsize="middle"
                        android:singleLine="true"
                        android:paddingBottom="4dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <Button
                            android:id="@+id/btnCdLoadDisc"
                            android:layout_width="wrap_content"
                            android:layout_height="42dp"
                            android:text="\uD83D\uDCBF Load Disc"
                            android:textSize="13sp"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#37474F"
                            style="@style/QuickButtonPrimary" />

                        <Button
                            android:id="@+id/btnCdPlay"
                            android:layout_width="wrap_content"
                            android:layout_height="42dp"
                            android:layout_marginStart="12dp"
                            android:text="\u25B6 Play"
                            android:textSize="13sp"
                            android:textColor="#FFFFFF"
                            android:backgroundTint="#2E7D32"
                            style="@style/QuickButtonPrimary" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Ext ROM (CD32 only, shown at bottom of media section) -->
                <LinearLayout
                    android:id="@+id/extRomSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_section_kickstart"
                    android:orientation="vertical"
                    android:padding="6dp"
                    android:visibility="gone">
                    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingBottom="4dp" android:text="CD32 Extended ROM" android:textStyle="bold" android:textSize="12sp" />
                    <TextView android:id="@+id/txtExtStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Ext ROM: (not selected)" android:textSize="12sp" />
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/quickstartReturnBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_section_model"
                android:padding="2dp"
                android:visibility="visible">

                <Button
                    android:id="@+id/btnResumeToEmu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="#2E7D32"
                    android:textColor="#FFFFFF"
                    style="@style/QuickButtonPrimary"
                    android:text="Resume" />

                <Button
                    android:id="@+id/btnRestartEmu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="#2E7D32"
                    android:textColor="#FFFFFF"
                    style="@style/QuickButtonPrimary"
                    android:text="Restart" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/btnCdCorner"
        android:layout_width="wrap_content"
        android:layout_height="96dp"
        style="@style/IconChipSmall"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="8dp"
        android:background="@android:color/transparent"
        android:text="💿 Load CD"
        android:textColor="@android:color/white"
        android:textSize="30sp"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/splashImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/splash_screen"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:background="#000000" />
</FrameLayout>
