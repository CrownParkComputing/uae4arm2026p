<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/bootstrapScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/bootstrapRoot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/txtTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Quickstart"
                android:textSize="20sp"
                android:textStyle="bold"
                android:paddingBottom="6dp"
                android:visibility="visible" />

            <LinearLayout
                android:id="@+id/sectionModel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_section_model"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="6dp"
                    android:text="Model"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.2"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Amiga model" />

                        <Spinner
                            android:id="@+id/spinnerQsModel"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1.3"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Config" />

                        <Spinner
                            android:id="@+id/spinnerQsConfig"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content" />

                        <TextView
                            android:id="@+id/txtQsConfigFull"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:textSize="12sp"
                            android:textColor="?android:attr/textColorSecondary"
                            android:text="" />

                    </LinearLayout>
                </LinearLayout>

                <!-- Quick access buttons (3 columns so all are on one line) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnModelCpuFpu"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="CPU &amp; FPU"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/btnModelChipset"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Chipset"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/btnModelRam"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="RAM"
                        android:textSize="12sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnModelSound"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Sound"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/btnModelInput"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Input"
                        android:textSize="12sp" />

                    <Button
                        android:id="@+id/btnKickMap"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Kickstart"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- Kickstart status below Model buttons -->
                <TextView
                    android:id="@+id/txtKickStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Kickstart: (not selected)"
                    android:textSize="12sp"
                    android:visibility="visible" />

            </LinearLayout>

            <!-- Ext ROM section for CD32 -->
            <LinearLayout
                android:id="@+id/extRomSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_section_kickstart"
                android:orientation="vertical"
                android:padding="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingBottom="6dp"
                    android:text="CD32 Extended ROM"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txtExtStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ext ROM: (not selected)" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/sectionMedia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_section_media"
                android:orientation="vertical"
                android:padding="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingBottom="6dp"
                        android:text="Media loading"
                        android:textStyle="bold" />

                </LinearLayout>

                <TextView
                    android:id="@+id/txtBootMediumLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:text="Boot from"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnAddDf1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        style="@style/QuickButton"
                        android:backgroundTint="#2F80ED"
                        android:textColor="#FFFFFF"
                        android:text="DF" />

                    <Button
                        android:id="@+id/btnWHDBooter"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        style="@style/QuickButton"
                        android:backgroundTint="#2F80ED"
                        android:textColor="#FFFFFF"
                        android:text="WHDBooter" />

                    <Button
                        android:id="@+id/btnAddDh0"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        style="@style/QuickButton"
                        android:backgroundTint="#2F80ED"
                        android:textColor="#FFFFFF"
                        android:text="+ HD" />

                    <Button
                        android:id="@+id/btnAddCd0"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        style="@style/QuickButton"
                        android:backgroundTint="#2F80ED"
                        android:textColor="#FFFFFF"
                        android:text="+ CD" />

                </LinearLayout>

                <!-- Floppy first -->
                <TextView
                    android:id="@+id/txtDf0Status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="10dp"
                    android:text="DF0: (not selected)" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:visibility="gone">

                    <Button
                        android:id="@+id/btnPickDf0"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        style="@style/QuickButton"
                        android:text="ADF/Floppy" />

                    <Button
                        android:id="@+id/btnClearDf0"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/QuickButton"
                        android:text="Clear" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/df1Controls"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/txtDf1Status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="DF1: (not selected)" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <Button
                            android:id="@+id/btnPickDf1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            style="@style/QuickButton"
                            android:text="ADF/Floppy" />

                        <Button
                            android:id="@+id/btnClearDf1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/QuickButton"
                            android:text="Clear" />
                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/dh0Section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/txtDh0Status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="12dp"
                        android:text="DH0: (not selected)" />

                    <TextView
                        android:id="@+id/txtDh1Status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="6dp"
                        android:text="DH1: (not selected)" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cd0Section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/txtCd0Status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingTop="6dp"
                        android:text="CD-ROM: (not selected)" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnPickCd0"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            style="@style/QuickButton"
                            android:text="BIN/CUE/ISO" />

                        <Button
                            android:id="@+id/btnClearCd0"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            style="@style/QuickButton"
                            android:text="Clear" />
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- Main actions row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnConfigs"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="#1565C0"
                    android:textColor="#FFFFFF"
                    style="@style/QuickButton"
                    android:text="Configs" />

                <Button
                    android:id="@+id/btnSetup"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#6A1B9A"
                    android:textColor="#FFFFFF"
                    style="@style/QuickButton"
                    android:text="Setup" />

                <Button
                    android:id="@+id/btnHelp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#EF6C00"
                    android:textColor="#FFFFFF"
                    style="@style/QuickButton"
                    android:text="Help" />

                <Button
                    android:id="@+id/btnStart"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="#2E7D32"
                    android:textColor="#FFFFFF"
                    style="@style/QuickButtonPrimary"
                    android:text="Start" />

            </LinearLayout>

            <TextView
                android:id="@+id/txtHint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Tip: Import DF0/DF1 disks as needed. Use Quickstart to set the default machine." />

            <LinearLayout
                android:id="@+id/quickstartReturnBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_section_model"
                android:padding="8dp"
                android:visibility="visible">

                <Button
                    android:id="@+id/btnResumeToEmu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="#2E7D32"
                    android:textColor="#FFFFFF"
                    style="@style/QuickButtonPrimary"
                    android:text="Resume" />

                <Button
                    android:id="@+id/btnRestartEmu"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="#2E7D32"
                    android:textColor="#FFFFFF"
                    style="@style/QuickButtonPrimary"
                    android:text="Restart" />

                <Button
                    android:id="@+id/btnExitTop"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:text="Exit" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <ImageView
        android:id="@+id/splashImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/splash_screen"
        android:scaleType="centerCrop"
        android:visibility="gone"
        android:background="#000000" />
</FrameLayout>
