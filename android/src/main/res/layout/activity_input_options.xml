<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF202020"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp"
        android:text="Input Options"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold" />

    <CheckBox
        android:id="@+id/chkInputUsePreset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Use Quickstart Defaults"
        android:textColor="#FFFFFF" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Controller Source"
            android:textColor="#FFFFFF" />

        <Spinner
            android:id="@+id/spinnerControllerSource"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FF444444" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Port 0 (Mouse Port)"
            android:textColor="#FFFFFF" />

        <Spinner
            android:id="@+id/spinnerPort0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FF444444" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Port 1 (Joystick Port)"
            android:textColor="#FFFFFF" />

        <Spinner
            android:id="@+id/spinnerPort1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FF444444" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mouse Speed"
            android:textColor="#FFFFFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <SeekBar
                android:id="@+id/seekMouseSpeed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/txtMouseSpeedInfo"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="100%"
                android:textColor="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>

    <CheckBox
        android:id="@+id/chkAutofire"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Enable Autofire"
        android:textColor="#FFFFFF" />

    <CheckBox
        android:id="@+id/chkControllerMouseRemap"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Controller Mouse Remap (thumbstick/D-Pad + buttons control mouse)"
        android:textColor="#FFFFFF" />

    <Button
        android:id="@+id/btnJoyMapping"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Joy Mapping" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="bottom"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnInputBack"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Back" />

        <Button
            android:id="@+id/btnInputSave"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Save" />
    </LinearLayout>

</LinearLayout>
