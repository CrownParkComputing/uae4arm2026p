<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:padding="12dp"
    android:paddingBottom="32dp">

    <TextView
        android:id="@+id/txtConfigsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Configs"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvConfigFolder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/txtConfigsTitle"
        android:layout_marginTop="8dp"
        android:text=""
        android:textSize="12sp" />

    <Button
        android:id="@+id/btnConfigsRefresh"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvConfigFolder"
        android:layout_marginTop="8dp"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:text="Refresh"
        android:textSize="12sp" />

    <LinearLayout
        android:id="@+id/configButtonsPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="8dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnConfigsLoad"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:text="Load"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnConfigsSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:text="Save"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnConfigsRename"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:text="Rename"
                android:textSize="12sp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnConfigsDelete"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:text="Delete"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnConfigsViewText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:text="View Text"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnConfigsBack"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingHorizontal="10dp"
                android:paddingVertical="6dp"
                android:text="Back"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

    <ListView
        android:id="@+id/lvConfigs"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/configButtonsPanel"
        android:layout_below="@id/btnConfigsRefresh"
        android:layout_marginTop="8dp" />

</RelativeLayout>
