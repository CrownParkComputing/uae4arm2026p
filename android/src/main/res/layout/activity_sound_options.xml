<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sound"
            android:textSize="20sp"
            android:textStyle="bold" />

        <CheckBox
            android:id="@+id/chkSoundUsePreset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Use machine preset (no overrides)" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Sound Emulation"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/radioSoundOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <RadioButton
                android:id="@+id/radioSoundDisabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Disabled" />

            <RadioButton
                android:id="@+id/radioSoundDisabledEmu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Disabled, but emulated" />

            <RadioButton
                android:id="@+id/radioSoundEnabled"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Enabled" />
        </RadioGroup>

        <CheckBox
            android:id="@+id/chkSoundAutoSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Automatic switching" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Format"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Channel mode:" />
        <Spinner
            android:id="@+id/spinnerSoundChannelMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Frequency:" />
        <Spinner
            android:id="@+id/spinnerSoundFrequency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Swap channels:" />
        <Spinner
            android:id="@+id/spinnerSoundSwapChannels"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Stereo separation:" />
        <Spinner
            android:id="@+id/spinnerSoundStereoSeparation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Stereo delay:" />
        <Spinner
            android:id="@+id/spinnerSoundStereoDelay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Interpolation:" />
        <Spinner
            android:id="@+id/spinnerSoundInterpolation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Filter:" />
        <Spinner
            android:id="@+id/spinnerSoundFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Volume"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Paula Volume:" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <SeekBar
                android:id="@+id/seekPaulaVol"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
            <TextView
                android:id="@+id/txtPaulaVolInfo"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="100%" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CD Volume:" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <SeekBar
                android:id="@+id/seekCdVol"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
            <TextView
                android:id="@+id/txtCdVolInfo"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="100%" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AHI Volume:" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <SeekBar
                android:id="@+id/seekAhiVol"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
            <TextView
                android:id="@+id/txtAhiVolInfo"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="100%" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MIDI Volume:" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <SeekBar
                android:id="@+id/seekMidiVol"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
            <TextView
                android:id="@+id/txtMidiVolInfo"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="100%" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Floppy Drive Sound Emulation"
            android:textStyle="bold" />

        <CheckBox
            android:id="@+id/chkFloppySound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable floppy drive sound" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Empty drive:" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <SeekBar
                android:id="@+id/seekFloppyEmpty"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
            <TextView
                android:id="@+id/txtFloppyEmptyInfo"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="67%" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Disk in drive:" />
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <SeekBar
                android:id="@+id/seekFloppyDisk"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
            <TextView
                android:id="@+id/txtFloppyDiskInfo"
                android:layout_width="56dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="67%" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Sound Buffer"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sound Buffer Size:" />
        <Spinner
            android:id="@+id/spinnerSoundMaxBuff"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <RadioGroup
            android:id="@+id/radioPullPush"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/radioPullAudio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pull audio" />

            <RadioButton
                android:id="@+id/radioPushAudio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Push audio" />
        </RadioGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnSoundSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Save" />

            <Button
                android:id="@+id/btnSoundReset"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Reset" />

            <Button
                android:id="@+id/btnSoundBack"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Back" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Tip: Enable overrides to change channels/frequency; keep preset to use Quickstart defaults." />

    </LinearLayout>
</ScrollView>
