<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Chipset"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Chipset" />

                <RadioGroup
                    android:id="@+id/radioChipset"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <RadioButton
                        android:id="@+id/radioChipsetOcs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="OCS" />

                    <RadioButton
                        android:id="@+id/radioChipsetEcsAgnus"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ECS Agnus" />

                    <RadioButton
                        android:id="@+id/radioChipsetEcsDenise"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="ECS Denise" />

                    <RadioButton
                        android:id="@+id/radioChipsetFullEcs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Full ECS" />

                    <RadioButton
                        android:id="@+id/radioChipsetAga"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="AGA" />
                </RadioGroup>

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Chipset Extra" />

                <Spinner
                    android:id="@+id/spinnerChipsetCompatible"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

                <CheckBox
                    android:id="@+id/chkNtsc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="NTSC" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cycle Exact" />

                <CheckBox
                    android:id="@+id/chkCycleExactFull"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cycle Exact (Full)" />

                <CheckBox
                    android:id="@+id/chkCycleExactMemory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cycle Exact (DMA/Memory)" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnChipsetSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Save" />

            <Button
                android:id="@+id/btnChipsetReset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reset" />

            <Button
                android:id="@+id/btnChipsetBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Back" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
