# Amiberry files
conf/*.uae
conf/*.conf
roms/*.rom
roms/*.key
/amiberry.conf
/amiberry.log

# Local debug/build artifacts (do not commit)
_redir_test.txt
InstallationLog.txt
vkbd_logcat*.txt
logcat_*.txt
buildlog-*.txt
assembleDebug_run*.txt
*stacktrace*.txt
projects_out*.txt
projects_stacktrace*.txt

# Android local build output dumps
android/gradle_assembleDebug.txt
android/gradle_setup_build.txt
android/last_build*.txt
android/found_apks.txt
android/device_bootstrap_prefs*.xml

# Android local crash/logcat captures
android/*logcat*.txt
