android/*_logs.txt
android/*_scan.txt
android/*.txt
*.log
*.err.log

# Consolidated local debug artifacts
artifacts/local-debug/

# --- Android local ROM assets (do not commit) ---
# If you want to bundle AROS ROMs into the APK, place them in either:
# - android/src/main/assets/roms/ (direct)
# - android/roms-src/roms/ (preferred; build.gradle adds this as an extra assets dir)
android/src/main/assets/roms/aros-rom.bin
android/src/main/assets/roms/aros-ext.bin
android/roms-src/roms/aros-rom.bin
android/roms-src/roms/aros-ext.bin

# Generated WHDboot assets are bundled from ../whdboot
android/src/main/assets/whdboot/

# --- Large HDF files (do not commit) ---
*.hdf
whdboot/boot-hdf/

# --- Android signing (do not commit) ---
android/keystore.properties
android/keystore/*.jks
android/keystore/*.keystore

